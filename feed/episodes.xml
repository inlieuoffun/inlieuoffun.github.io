<?xml version="1.0" encoding="utf-8"?><feed xmlns="http://www.w3.org/2005/Atom" ><generator uri="https://jekyllrb.com/" version="4.1.1">Jekyll</generator><link href="https://inlieuof.fun/feed/episodes.xml" rel="self" type="application/atom+xml" /><link href="https://inlieuof.fun/" rel="alternate" type="text/html" /><updated>2021-07-20T20:22:20+00:00</updated><id>https://inlieuof.fun/feed/episodes.xml</id><title type="html">In Lieu of Fun | Episodes</title><subtitle>&quot;And...we're live!&quot; A webcast hosted by Ben Wittes and Kate Klonick.</subtitle><entry><title type="html">0474</title><link href="https://inlieuof.fun/episode/2021-07-20-0474" rel="alternate" type="text/html" title="0474" /><published>2021-07-20T00:00:00+00:00</published><updated>2021-07-20T00:00:00+00:00</updated><id>https://inlieuof.fun/episode/0474</id><author><name></name></author><summary type="html">Sheera Frenkel and Cecilia Kang join us to discuss their new book, “An Ugly Truth: Inside Facebook’s Battle for Domination”.</summary></entry><entry><title type="html">0473</title><link href="https://inlieuof.fun/episode/2021-07-19-0473" rel="alternate" type="text/html" title="0473" /><published>2021-07-19T00:00:00+00:00</published><updated>2021-07-19T00:00:00+00:00</updated><id>https://inlieuof.fun/episode/0473</id><author><name></name></author><summary type="html"></summary></entry><entry><title type="html">0472</title><link href="https://inlieuof.fun/episode/2021-07-16-0472" rel="alternate" type="text/html" title="0472" /><published>2021-07-16T00:00:00+00:00</published><updated>2021-07-16T00:00:00+00:00</updated><id>https://inlieuof.fun/episode/0472</id><author><name></name></author><summary type="html"></summary></entry><entry><title type="html">0471</title><link href="https://inlieuof.fun/episode/2021-07-15-0471" rel="alternate" type="text/html" title="0471" /><published>2021-07-15T00:00:00+00:00</published><updated>2021-07-15T00:00:00+00:00</updated><id>https://inlieuof.fun/episode/0471</i